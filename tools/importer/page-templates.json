{
  "templates": [
    {
      "name": "homepage",
      "urls": [
        "https://www.nationwide.co.uk"
      ],
      "description": "Nationwide Building Society homepage with hero banner, product navigation cards, feature cards, call checker, internet banking, service quality rankings, and APP scams data",
      "blocks": [
        {
          "name": "hero",
          "instances": [
            "div[class*=\"StyledCompoenents__HeroContainerInner\"]"
          ]
        },
        {
          "name": "cards",
          "instances": [
            "ol[class*=\"IconBlock__StyledOl\"]",
            "div[class*=\"CardsGrid__StyledCardsGrid\"]"
          ]
        },
        {
          "name": "columns",
          "instances": [
            "div[class*=\"vertical-rhythm--image-with-content\"]",
            "div[class*=\"SideBySideLayout__SideBySideGrid\"]"
          ]
        },
        {
          "name": "default-content",
          "instances": [
            "div[class*=\"ContentWithSidebar__ContentWithSideBarGrid\"]"
          ],
          "section": "narrow-text"
        }
      ],
      "sections": {
        "footnote": {
          "selector": "p:has(text*='PayUK quarterly')",
          "description": "Disclaimer footnote referencing PayUK switch data"
        }
      }
    },
    {
      "name": "product-landing",
      "urlPatterns": [
        "https://www.nationwide.co.uk/current-accounts",
        "https://www.nationwide.co.uk/savings",
        "https://www.nationwide.co.uk/mortgages",
        "https://www.nationwide.co.uk/loans",
        "https://www.nationwide.co.uk/credit-cards",
        "https://www.nationwide.co.uk/insurance"
      ],
      "description": "Product landing pages with hero, product cards grid, feature sections, and help/FAQ area. Common pattern: Hero → promo Columns (light) → Cards grid → feature Columns (light) → Cards grid → feature Columns (light) → Cards grid → default content → help links → FSCS Columns → footnotes",
      "blocks": [
        {
          "name": "hero",
          "instances": [
            "div[class*=\"StyledCompoenents__HeroContainerInner\"]"
          ]
        },
        {
          "name": "cards",
          "instances": [
            "div[class*=\"CardsGrid__StyledCardsGrid\"]",
            "ol[class*=\"IconBlock__StyledOl\"]",
            "div[class*=\"ActionCard__ActionCardOuter\"]"
          ]
        },
        {
          "name": "columns",
          "instances": [
            "div[class*=\"vertical-rhythm--image-with-content\"]",
            "div[class*=\"SideBySideLayout__SideBySideGrid\"]"
            "div[class*=\"ImageWithContent__StyledContentArea\"]",
            "div[class*=\"SideBySideLayout__SideBySideGrid\"]",
            "div[class*=\"ContentWithSidebar__ContentWithSideBarGrid\"]:has(img)"
          ]
        },
        {
          "name": "default-content",
          "instances": [
            "div[class*=\"ContentWithSidebar__ContentWithSideBarGrid\"]:not(:has(img))"
          ]
        }
      ],
      "sectionStyles": {
        "light": "Applied to Columns sections with award badges, promo panels, and feature highlights",
        "footnote": "Applied to SmallPrint disclaimer section at page bottom"
      }
    },
    {
      "name": "product-detail",
      "urlPatterns": [
        "https://www.nationwide.co.uk/current-accounts/flexdirect",
        "https://www.nationwide.co.uk/current-accounts/flexplus",
        "https://www.nationwide.co.uk/current-accounts/flexaccount",
        "https://www.nationwide.co.uk/current-accounts/flexstudent",
        "https://www.nationwide.co.uk/current-accounts/flexone",
        "https://www.nationwide.co.uk/current-accounts/flexbasic",
        "https://www.nationwide.co.uk/savings/*",
        "https://www.nationwide.co.uk/mortgages/*",
        "https://www.nationwide.co.uk/loans/*",
        "https://www.nationwide.co.uk/credit-cards/*",
        "https://www.nationwide.co.uk/insurance/*"
      ],
      "description": "Product detail pages with hero, feature sections (columns + accordion), comparison tables, and help links. Common pattern: Hero → promo Columns (light) + Accordion → feature Columns (dark) → award Columns (light) → icon Cards → Table (striped) → document links → CTA Columns (dark) → comparison Table (striped) → Columns (light) → Cards → FSCS Columns → footnotes",
      "blocks": [
        {
          "name": "hero",
          "instances": [
            "div[class*=\"StyledCompoenents__HeroContainerInner\"]"
          ]
        },
        {
          "name": "accordion",
          "instances": [
            "div[class*=\"nel-Accordion\"]",
            "[class*=\"Accordion__StyledAccordion\"]"
          ]
        },
        {
          "name": "cards",
          "instances": [
            "ol[class*=\"IconBlock__StyledOl\"]",
            "div[class*=\"CardsGrid__StyledCardsGrid\"]",
            "div[class*=\"LinkCard__Card\"]"
          ]
        },
        {
          "name": "columns",
          "instances": [
            "div[class*=\"ImageWithContent__StyledContentArea\"]",
            "div[class*=\"SideBySideLayout__SideBySideGrid\"]",
            "div[class*=\"ContentWithSidebar__ContentWithSideBarGrid\"]:has(img)"
          ]
        },
        {
          "name": "table",
          "instances": [
            "table[class*=\"SimpleTable\"]",
            "div[class*=\"CurrentAccountsTable\"]",
            "div[class*=\"ComparisonTable\"]"
          ]
        },
        {
          "name": "default-content",
          "instances": [
            "div[class*=\"ContentWithSidebar__ContentWithSideBarGrid\"]:not(:has(img))",
            "div[class*=\"SmallPrint\"]"
          ]
        }
      ],
      "sectionStyles": {
        "light": "Applied to Columns sections with award badges, promo panels, and feature highlights",
        "dark": "Applied to feature list sections and full-width CTA sections",
        "footnote": "Applied to SmallPrint disclaimer sections"
      }
    },
